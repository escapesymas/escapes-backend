# ============================================================
# ESCAPES Y MÁS — Server Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ============================================================

# --- Server ---
PORT=3001

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/escapes_db

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_...

# --- SMTP (Mail) ---
SMTP_HOST=smtp.buzondecorreo.com
SMTP_PORT=465
SMTP_USER=web@escapesymas.com
SMTP_PASSWORD=your-smtp-password

# --- WooCommerce ---
WP_URL=https://backendescapes.com
WOO_KEY=ck_...
WOO_SECRET=cs_...

# --- Bihr (Dropshipping) ---
BIHR_API_BASE=https://api.bihr.net
BIHR_USERNAME=info@escapesymas.com
BIHR_MACKEY=your-bihr-mackey

# --- JWT Admin ---
JWT_ADMIN_SECRET=change-this-to-a-long-random-string

# --- Chatbot IA (MiniMax / OpenAI-compatible) ---
# Token Plan key: https://platform.minimax.io/user-center/basic-information/interface-key
MINIMAX_API_KEY=your-minimax-token-plan-key
