{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["*.ts", "routes/*.ts", "chatbot/**/*.ts", "templates/**/*.ts", "lib/**/*.ts", "schemas/**/*.ts", "migrations/**/*.ts"],
  "exclude": ["node_modules", "dist", "scripts", "e2e", "tests"]
}