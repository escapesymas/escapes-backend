# Environment configuration for image regeneration script
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=escapes_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# Bihr API (get credentials from your Bihr account)
BIHR_API_BASE=https://api.bihr.net
BIHR_USERNAME=your_bihr_username
BIHR_MACKEY=your_bihr_mackey